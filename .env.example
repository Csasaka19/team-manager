# ─────────────────────────────────────────────────────────────────────────────
# Atlas Control Center — read-only public API
#
# The team-manager app pulls a live feed (projects, summaries, tasks,
# manifests, recent activity) from a Control Center / Atlas vault instance.
# The API is read-only: nothing the app does mutates Atlas state.
#
# Both vars MUST be prefixed with VITE_ so Vite exposes them to the browser
# bundle. Treat the token as sensitive — it ships in the compiled JS, so this
# is only appropriate for trusted internal deployments. For untrusted users,
# proxy these calls through your own backend instead.
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL for the Atlas public API. No trailing slash.
# Example: http://localhost:4005/api/public
#          https://atlas.your-domain.com/api/public
VITE_ATLAS_BASE_URL=http://localhost:4005/api/public

# Bearer token from the Atlas server's READ_API_TOKEN env var.
# All /api/public/* requests send `Authorization: Bearer <token>`.
# Leave blank to disable the integration — the Atlas pages will render a
# "not configured" state with a link to Settings.
VITE_ATLAS_TOKEN=
